<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<LinearLayout
		android:id="@+id/background"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:padding="4dp"
		android:background="#212121"
		android:gravity="center_horizontal|top"
		android:orientation="vertical">
		<TextView
			android:id="@+id/TextView3"
			android:focusable="false"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:text="Settings"
			android:textSize="18sp"
			android:textColor="#FFFFFF" />
		<ScrollView
			android:id="@+id/ScrollView1"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:layout_weight="1"
			android:fillViewport="true"
			android:fadingEdgeLength="13dp"
			android:requiresFadingEdge="vertical"
			android:fadeScrollbars="false"
			android:overScrollMode="never"
			android:scrollbars="none">
			<LinearLayout
				android:id="@+id/scrollcontainer"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:orientation="vertical">
				<LinearLayout
					android:id="@+id/linear8"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:gravity="center_vertical"
					android:orientation="horizontal">
					<LinearLayout
						android:id="@+id/linear9"
						android:layout_width="25dp"
						android:layout_height="1dp"
						android:background="#616161"
						android:orientation="vertical" />
					<TextView
						android:id="@+id/textview1"
						android:focusable="false"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:text="General"
						android:textSize="12sp"
						android:textColor="#FFFFFF" />
					<LinearLayout
						android:id="@+id/linear10"
						android:layout_width="match_parent"
						android:layout_height="1dp"
						android:background="#616161"
						android:orientation="vertical" />
				</LinearLayout>
				<LinearLayout
					android:id="@+id/o1sw"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="horizontal">
					<Switch
						android:id="@+id/antialiassw"
						android:focusable="false"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:gravity="left|center_vertical"
						android:text="Anti-aliasing"
						android:textSize="14sp"
						android:textColor="#FFFFFF"
						android:layout_weight="1" />
				</LinearLayout>
				<LinearLayout
					android:id="@+id/o2sw"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="horizontal">
					<Switch
						android:id="@+id/askexitsw"
						android:focusable="false"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:gravity="left|center_vertical"
						android:text="Ask for confirmation before ending the session"
						android:textSize="14sp"
						android:textColor="#FFFFFF"
						android:layout_weight="1" />
				</LinearLayout>
				<LinearLayout
					android:id="@+id/o3"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:gravity="left|center_vertical"
					android:orientation="horizontal">
					<TextView
						android:id="@+id/TextView4"
						android:focusable="false"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:text="Default color picker color: "
						android:textSize="14sp"
						android:textColor="#FFFFFF"
						android:layout_weight="1" />
					<LinearLayout
						android:id="@+id/col"
						android:layout_width="50dp"
						android:layout_height="50dp"
						android:padding="8dp"
						android:background="#000000"
						android:orientation="vertical" />
				</LinearLayout>
				<LinearLayout
					android:id="@+id/linear11"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:gravity="center_vertical"
					android:orientation="horizontal">
					<LinearLayout
						android:id="@+id/linear12"
						android:layout_width="25dp"
						android:layout_height="1dp"
						android:background="#616161"
						android:orientation="vertical" />
					<TextView
						android:id="@+id/textview2"
						android:focusable="false"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:text="Rendering"
						android:textSize="12sp"
						android:textColor="#FFFFFF" />
					<LinearLayout
						android:id="@+id/linear13"
						android:layout_width="match_parent"
						android:layout_height="1dp"
						android:background="#616161"
						android:orientation="vertical" />
				</LinearLayout>
				<LinearLayout
					android:id="@+id/LinearLayout17"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical">
					<TextView
						android:id="@+id/TextView5"
						android:focusable="false"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:text="The canvas will render using "
						android:textSize="14sp"
						android:textColor="#FFFFFF" />
					<RadioGroup
						android:id="@+id/RadioGroup1"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:orientation="vertical">
						<RadioButton
							android:id="@+id/gpu_rb"
							android:focusable="false"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:padding="8dp"
							android:text="GPU (Fastest)"
							android:textSize="12sp"
							android:textColor="#FFFFFF"
							android:checked="true" />
						<RadioButton
							android:id="@+id/cpu_rb"
							android:focusable="false"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:padding="8dp"
							android:text="CPU (Not recommended)"
							android:textSize="12sp"
							android:textColor="#FFFFFF" />
					</RadioGroup>
				</LinearLayout>
				<LinearLayout
					android:id="@+id/linear18"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical">
					<TextView
						android:id="@+id/textview6"
						android:focusable="false"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:paddingLeft="8dp"
						android:paddingTop="8dp"
						android:paddingRight="8dp"
						android:text="Max proxy pixels"
						android:textSize="14sp"
						android:textColor="#FFFFFF" />
					<TextView
						android:id="@+id/TextView7"
						android:focusable="false"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:paddingLeft="8dp"
						android:paddingRight="8dp"
						android:paddingBottom="8dp"
						android:text="The maximum number of pixels it renders on canvas (this will not affect the actual size of the final image saved on your device, but it will affect the quality)."
						android:textSize="12sp"
						android:textColor="#9E9E9E" />
					<RadioGroup
						android:id="@+id/radiogroup2"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:orientation="vertical">
						<RadioButton
							android:id="@+id/prox4096"
							android:focusable="false"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:padding="8dp"
							android:text="4096"
							android:textSize="12sp"
							android:textColor="#FFFFFF" />
						<RadioButton
							android:id="@+id/prox2048"
							android:focusable="false"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:padding="8dp"
							android:text="2048 (Recommended)"
							android:textSize="12sp"
							android:textColor="#FFFFFF"
							android:checked="true" />
						<RadioButton
							android:id="@+id/prox1280"
							android:focusable="false"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:padding="8dp"
							android:text="1280"
							android:textSize="12sp"
							android:textColor="#FFFFFF" />
						<RadioButton
							android:id="@+id/prox720"
							android:focusable="false"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:padding="8dp"
							android:text="720"
							android:textSize="12sp"
							android:textColor="#FFFFFF" />
						<RadioButton
							android:id="@+id/prox512"
							android:focusable="false"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:padding="8dp"
							android:text="512"
							android:textSize="12sp"
							android:textColor="#FFFFFF" />
					</RadioGroup>
				</LinearLayout>
			</LinearLayout>
		</ScrollView>
		<LinearLayout
			android:id="@+id/LinearLayout8"
			android:layout_width="match_parent"
			android:layout_height="50dp"
			android:layout_marginTop="6dp"
			android:orientation="horizontal">
			<TextView
				android:id="@+id/dismiss_bttn"
				android:focusable="false"
				android:layout_width="wrap_content"
				android:layout_height="match_parent"
				android:gravity="center_horizontal|center_vertical"
				android:text="Dismiss"
				android:textSize="18sp"
				android:textColor="#FFFFFF"
				android:layout_weight="1" />
		</LinearLayout>
	</LinearLayout>
</LinearLayout>

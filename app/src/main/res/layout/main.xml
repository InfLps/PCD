<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
android:background="@color/colorPrimary"
android:fitsSystemWindows="true"
	android:orientation="vertical">
	<FrameLayout
		android:id="@+id/rootBackground"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:background="#333333"
		android:gravity="center_horizontal|center_vertical"
		android:orientation="vertical">
		<com.inflps.pcd.DrawingView
			android:id="@+id/pdv"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:background="#FFFFFF"
			android:orientation="horizontal"
			android:layout_weight="1" />
		<LinearLayout
			android:id="@+id/main_container"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:orientation="vertical">
			<FrameLayout
				android:id="@+id/foreground"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:orientation="vertical">
				<LinearLayout
					android:id="@+id/toolbar"
					android:layout_width="match_parent"
					android:layout_height="60dp"
					android:orientation="horizontal"
					android:layout_gravity="top">
					<LinearLayout
						android:id="@+id/tb1"
						android:layout_width="55dp"
						android:layout_height="50dp"
						android:padding="4dp"
						android:gravity="center_horizontal|center_vertical"
						android:orientation="horizontal"
						android:layout_weight="1"
						android:animateLayoutChanges="true">
						<ImageView
							android:id="@+id/back"
							android:layout_width="40dp"
							android:layout_height="40dp"
							android:padding="8dp"
							android:src="@drawable/ic_arrow_back_white"
							android:scaleType="fitCenter" />
						<EditText
							android:id="@+id/projtitle"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_marginLeft="4dp"
							android:layout_marginRight="4dp"
							android:background="@android:color/transparent"
							android:textSize="16sp"
							android:textColor="#FFFFFF"
							android:hint="Project title"
							android:textColorHint="#9E9E9E"
							android:singleLine="true"
							android:imeOptions="actionDone"
							android:enabled="false"
							android:layout_weight="1"
							android:requiresFadingEdge="horizontal" />
						<ImageView
							android:id="@+id/commit"
							android:layout_width="40dp"
							android:layout_height="40dp"
							android:padding="8dp"
							android:src="@drawable/check"
							android:scaleType="fitCenter"
							android:visibility="gone" />
						<ImageView
							android:id="@+id/undo"
							android:layout_width="40dp"
							android:layout_height="40dp"
							android:padding="8dp"
							android:src="@drawable/undo"
							android:scaleType="fitCenter" />
						<ImageView
							android:id="@+id/redo"
							android:layout_width="40dp"
							android:layout_height="40dp"
							android:padding="8dp"
							android:src="@drawable/redo"
							android:scaleType="fitCenter" />
						<ImageView
							android:id="@+id/more"
							android:layout_width="40dp"
							android:layout_height="40dp"
							android:padding="8dp"
							android:src="@drawable/more"
							android:scaleType="fitCenter" />
					</LinearLayout>
				</LinearLayout>
				<LinearLayout
					android:id="@+id/center_container"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:gravity="right|center_vertical"
					android:orientation="horizontal"
					android:layout_gravity="center_horizontal|center_vertical"
					android:layout_weight="1">
					<LinearLayout
						android:id="@+id/center_toolbar"
						android:layout_width="wrap_content"
						android:layout_height="match_parent"
						android:paddingLeft="4dp"
						android:paddingRight="4dp"
						android:gravity="center_horizontal|center_vertical"
						android:orientation="vertical"
						android:animateLayoutChanges="true">
						<LinearLayout
							android:id="@+id/inv"
							android:layout_width="50dp"
							android:layout_height="50dp"
							android:layout_marginBottom="12dp"
							android:padding="8dp"
							android:orientation="horizontal"
							android:visibility="gone" />
						<LinearLayout
							android:id="@+id/smudgePowerGroup"
							android:layout_width="50dp"
							android:layout_height="50dp"
							android:layout_marginBottom="12dp"
							android:gravity="center_horizontal|center_vertical"
							android:orientation="horizontal"
							android:visibility="gone">
							<com.inflps.pcd.WIDGET.CONTROL_VIEW.DragControlSmudgeView
								android:id="@+id/smudgePower"
								android:layout_width="40dp"
								android:layout_height="40dp"
								android:orientation="vertical" />
						</LinearLayout>
						<LinearLayout
							android:id="@+id/filltoleranceGroup"
							android:layout_width="50dp"
							android:layout_height="50dp"
							android:layout_marginBottom="12dp"
							android:gravity="center_horizontal|center_vertical"
							android:orientation="horizontal"
							android:visibility="gone">
							<com.inflps.pcd.WIDGET.CONTROL_VIEW.DragControlToleranceView
								android:id="@+id/filltolerance"
								android:layout_width="40dp"
								android:layout_height="40dp"
								android:orientation="vertical" />
						</LinearLayout>
						<LinearLayout
							android:id="@+id/swichPenGroup"
							android:layout_width="50dp"
							android:layout_height="50dp"
							android:layout_marginBottom="12dp"
							android:gravity="center_horizontal|center_vertical"
							android:orientation="horizontal">
							<com.inflps.pcd.WIDGET.CONTROL_VIEW.ToolSwapView
								android:id="@+id/switchPen"
								android:layout_width="40dp"
								android:layout_height="40dp"
								android:orientation="vertical" />
						</LinearLayout>
						<LinearLayout
							android:id="@+id/strokeColorGroup"
							android:layout_width="50dp"
							android:layout_height="50dp"
							android:layout_marginBottom="12dp"
							android:gravity="center_horizontal|center_vertical"
							android:orientation="horizontal">
							<com.inflps.pcd.WIDGET.CONTROL_VIEW.ColorScrubView
								android:id="@+id/col"
								android:layout_width="40dp"
								android:layout_height="40dp"
								android:orientation="vertical" />
						</LinearLayout>
						<LinearLayout
							android:id="@+id/strokeThicknessGroup"
							android:layout_width="50dp"
							android:layout_height="50dp"
							android:layout_marginBottom="12dp"
							android:gravity="center_horizontal|center_vertical"
							android:orientation="horizontal">
							<com.inflps.pcd.WIDGET.CONTROL_VIEW.DragControlView
								android:id="@+id/strokeThickness"
								android:layout_width="40dp"
								android:layout_height="40dp"
								android:orientation="vertical" />
						</LinearLayout>
						<LinearLayout
							android:id="@+id/objectAlphaGroup"
							android:layout_width="50dp"
							android:layout_height="50dp"
							android:gravity="center_horizontal|center_vertical"
							android:orientation="horizontal">
							<com.inflps.pcd.WIDGET.CONTROL_VIEW.DragControlOpacityView
								android:id="@+id/objectAlpha"
								android:layout_width="40dp"
								android:layout_height="40dp"
								android:orientation="vertical" />
						</LinearLayout>
					</LinearLayout>
					<LinearLayout
						android:id="@+id/spacebar2"
						android:layout_width="wrap_content"
						android:layout_height="0dp"
						android:orientation="vertical"
						android:layout_weight="1" />
					<LinearLayout
						android:id="@+id/lib"
						android:layout_width="45dp"
						android:layout_height="45dp"
						android:layout_marginTop="66dp"
						android:layout_marginBottom="56dp"
						android:gravity="center_horizontal|center_vertical"
						android:orientation="vertical"
						android:layout_gravity="top">
						<ImageView
							android:id="@+id/layers"
							android:layout_width="40dp"
							android:layout_height="40dp"
							android:padding="4dp"
							android:src="@drawable/layer"
							android:scaleType="fitCenter" />
					</LinearLayout>
					<LinearLayout
						android:id="@+id/lb"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginTop="66dp"
						android:layout_marginBottom="56dp"
						android:orientation="horizontal"
						android:layout_gravity="top"
						android:visibility="gone">
						<LinearLayout
							android:id="@+id/layer_container"
							android:layout_width="100dp"
							android:layout_height="wrap_content"
							android:orientation="vertical"
							android:layout_gravity="right">
							<LinearLayout
								android:id="@+id/new_layer_bttn"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:padding="2dp"
								android:gravity="center_horizontal|center_vertical"
								android:orientation="horizontal">
								<ImageView
									android:id="@+id/nlbttn_icon"
									android:layout_width="40dp"
									android:layout_height="40dp"
									android:padding="4dp"
									android:src="@drawable/add"
									android:scaleType="fitCenter" />
							</LinearLayout>
							<androidx.recyclerview.widget.RecyclerView
								android:id="@+id/layersRecyclerView"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:fillViewport="true"
								android:fadingEdgeLength="13dp"
								android:requiresFadingEdge="vertical"
								android:fadeScrollbars="false"
								android:overScrollMode="never"
								android:scrollbars="none" />
						</LinearLayout>
					</LinearLayout>
				</LinearLayout>
				<LinearLayout
					android:id="@+id/bttm_container"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical"
					android:layout_gravity="bottom">
					<LinearLayout
						android:id="@+id/LinearLayout1"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:orientation="vertical">
						<LinearLayout
							android:id="@+id/clear_all_bttn"
							android:layout_width="wrap_content"
							android:layout_height="45dp"
							android:layout_margin="6dp"
							android:gravity="center_horizontal|center_vertical"
							android:orientation="horizontal"
							android:layout_gravity="center_horizontal|top"
							android:visibility="gone"
							android:animateLayoutChanges="true">
							<TextView
								android:id="@+id/clear_text_bttn"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:layout_margin="6dp"
								android:gravity="center_horizontal|center_vertical"
								android:text="CLEAR CURRENT LAYER"
								android:textSize="12sp"
								android:textColor="#FFFFFF" />
						</LinearLayout>
					</LinearLayout>
					<LinearLayout
						android:id="@+id/bb1"
						android:layout_width="match_parent"
						android:layout_height="330dp"
						android:layout_marginLeft="40dp"
						android:layout_marginRight="40dp"
						android:paddingLeft="4dp"
						android:paddingRight="4dp"
						android:paddingBottom="4dp"
						android:gravity="center_horizontal|top"
						android:orientation="vertical">
						<LinearLayout
							android:id="@+id/h1"
							android:layout_width="match_parent"
							android:layout_height="50dp"
							android:gravity="center_vertical"
							android:orientation="horizontal">
							<ImageView
								android:id="@+id/pen"
								android:layout_width="40dp"
								android:layout_height="40dp"
								android:padding="6dp"
								android:src="@drawable/pen"
								android:scaleType="fitCenter"
								android:layout_weight="1" />
							<ImageView
								android:id="@+id/smudge"
								android:layout_width="40dp"
								android:layout_height="40dp"
								android:padding="6dp"
								android:src="@drawable/smudge"
								android:scaleType="fitCenter"
								android:layout_weight="1" />
							<ImageView
								android:id="@+id/text"
								android:layout_width="40dp"
								android:layout_height="40dp"
								android:padding="6dp"
								android:src="@drawable/text"
								android:scaleType="fitCenter"
								android:layout_weight="1" />
							<ImageView
								android:id="@+id/image"
								android:layout_width="40dp"
								android:layout_height="40dp"
								android:padding="6dp"
								android:src="@drawable/img"
								android:scaleType="fitCenter"
								android:layout_weight="1" />
							<ImageView
								android:id="@+id/bucket"
								android:layout_width="40dp"
								android:layout_height="40dp"
								android:padding="6dp"
								android:src="@drawable/fill"
								android:scaleType="fitCenter"
								android:layout_weight="1" />
							<ImageView
								android:id="@+id/shapes"
								android:layout_width="40dp"
								android:layout_height="40dp"
								android:padding="6dp"
								android:src="@drawable/shapes"
								android:scaleType="fitCenter"
								android:layout_weight="1" />
							<LinearLayout
								android:id="@+id/line"
								android:layout_width="1dp"
								android:layout_height="wrap_content"
								android:background="#9E9E9E"
								android:orientation="horizontal" />
							<ImageView
								android:id="@+id/arrow"
								android:layout_width="40dp"
								android:layout_height="40dp"
								android:padding="8dp"
								android:src="@drawable/arrowup"
								android:scaleType="fitCenter"
								android:layout_weight="1" />
						</LinearLayout>
						<LinearLayout
							android:id="@+id/chps"
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:orientation="horizontal">
							<LinearLayout
								android:id="@+id/textMode"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:orientation="vertical">
								<TextView
									android:id="@+id/textit"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:padding="2dp"
									android:text="Input text:"
									android:textSize="12sp"
									android:textColor="#FFFFFF" />
								<EditText
									android:id="@+id/textInput"
									android:layout_width="match_parent"
									android:layout_height="wrap_content"
									android:layout_margin="6dp"
									android:padding="8dp"
									android:background="#FFFFFF"
									android:text="Text"
									android:textSize="12sp"
									android:textColor="#000000"
									android:textColorHint="#607D8B"
									android:singleLine="true"
									android:imeOptions="actionDone"
									android:requiresFadingEdge="horizontal" />
								<TextView
									android:id="@+id/textt"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:layout_marginTop="4dp"
									android:padding="2dp"
									android:text="Typeface:"
									android:textSize="12sp"
									android:textColor="#FFFFFF" />
								<androidx.recyclerview.widget.RecyclerView
									android:id="@+id/fontRecyclerView"
									android:layout_width="match_parent"
									android:layout_height="match_parent" />
							</LinearLayout>
							<LinearLayout
								android:id="@+id/brushMode"
								android:layout_width="match_parent"
								android:layout_height="match_parent"
								android:orientation="vertical"
								android:animateLayoutChanges="true">
								<TextView
									android:id="@+id/warnTag"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:layout_margin="4dp"
									android:padding="4dp"
									android:text="..."
									android:textSize="12sp"
									android:textColor="#FFC107" />
								<androidx.recyclerview.widget.RecyclerView
									android:id="@+id/recycler_brushes"
									android:layout_width="match_parent"
									android:layout_height="match_parent"
									android:fillViewport="true" />
							</LinearLayout>
						</LinearLayout>
					</LinearLayout>
				</LinearLayout>
			</FrameLayout>
		</LinearLayout>
	</FrameLayout>
</LinearLayout>
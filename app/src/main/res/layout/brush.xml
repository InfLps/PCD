<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
android:layout_height="wrap_content"
android:background="@color/colorPrimary"
android:fitsSystemWindows="true"
	android:orientation="vertical">
	<LinearLayout
		android:id="@+id/background"
		android:layout_width="match_parent"
android:layout_height="wrap_content"
		android:background="#181818"
		android:orientation="vertical">
		<LinearLayout
			android:id="@+id/toolbar"
			android:layout_width="match_parent"
			android:layout_height="56dp"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="horizontal">
			<ImageView
				android:id="@+id/back"
				android:layout_width="40dp"
				android:layout_height="40dp"
				android:padding="8dp"
				android:src="@drawable/ic_arrow_back_white"
				android:scaleType="fitCenter" />
			<TextView
				android:id="@+id/title"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="2dp"
				android:text="Brush editor"
				android:textSize="18sp"
				android:textColor="#FFFFFF"
				android:layout_weight="1" />
			<ImageView
				android:id="@+id/export"
				android:layout_width="40dp"
				android:layout_height="40dp"
				android:padding="4dp"
				android:src="@drawable/download"
				android:scaleType="fitCenter" />
			<ImageView
				android:id="@+id/save"
				android:layout_width="40dp"
				android:layout_height="40dp"
				android:padding="8dp"
				android:src="@drawable/save"
				android:scaleType="fitCenter" />
		</LinearLayout>
		<LinearLayout
			android:id="@+id/brushPreviewContainer"
			android:layout_width="match_parent"
			android:layout_height="250dp"
			android:orientation="horizontal">
			<com.inflps.pcd.CORE.BRUSH_CORE.BrushPreviewView
				android:id="@+id/previewView"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:background="#424242"
				android:orientation="vertical" />
		</LinearLayout>
		<ScrollView
			android:id="@+id/scrollView"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:fillViewport="true"
			android:fadingEdgeLength="13dp"
			android:requiresFadingEdge="vertical"
			android:fadeScrollbars="false"
			android:overScrollMode="never"
			android:scrollbars="none">
			<LinearLayout
				android:id="@+id/scrollContainer"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:orientation="vertical">
				<TextView
					android:id="@+id/txtBN"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="2dp"
					android:text="Brush name"
					android:textSize="18sp"
					android:textColor="#FFFFFF" />
				<LinearLayout
					android:id="@+id/BNc_ner"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:orientation="horizontal">
					<EditText
						android:id="@+id/editName"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:background="@android:color/transparent"
						android:text="My brush"
						android:textSize="12sp"
						android:textColor="#FFFFFF"
						android:hint="..."
						android:textColorHint="#757575"
						android:singleLine="true"
						android:imeOptions="actionDone"
						android:requiresFadingEdge="horizontal" />
				</LinearLayout>
				<TextView
					android:id="@+id/txtB"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="2dp"
					android:text="Pattern (Bitmap)"
					android:textSize="18sp"
					android:textColor="#FFFFFF" />
				<LinearLayout
					android:id="@+id/TBc_ner"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:gravity="center_horizontal|center_vertical"
					android:orientation="horizontal">
					<ImageView
						android:id="@+id/bitmapPreview"
						android:layout_width="75dp"
						android:layout_height="75dp"
						android:src="@drawable/add"
						android:scaleType="fitCenter" />
					<LinearLayout
						android:id="@+id/c_ner1"
						android:layout_width="wrap_content"
						android:layout_height="match_parent"
						android:gravity="center_horizontal|center_vertical"
						android:orientation="vertical"
						android:layout_weight="1">
						<TextView
							android:id="@+id/imgFileName"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="img.png"
							android:textSize="16sp"
							android:textColor="#FFFFFF"
							android:singleLine="true"
							android:requiresFadingEdge="horizontal" />
						<TextView
							android:id="@+id/txtPick"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="Tap to pick image"
							android:textSize="12sp"
							android:textColor="#9E9E9E" />
					</LinearLayout>
				</LinearLayout>
				<LinearLayout
					android:id="@+id/TBFc_ner"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:orientation="horizontal">
					<CheckBox
						android:id="@+id/invertTextureCB"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:gravity="center_vertical"
						android:text="Negative filter"
						android:textSize="14sp"
						android:textColor="#FFFFFF" />
				</LinearLayout>
				<TextView
					android:id="@+id/txtS"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="2dp"
					android:text="Spacing"
					android:textSize="18sp"
					android:textColor="#FFFFFF" />
				<LinearLayout
					android:id="@+id/Sc_ner"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:orientation="horizontal">
					<com.inflps.pcd.WIDGET.SLIDERS.RotaryJogSlider
						android:id="@+id/spacingSeek"
						android:layout_width="wrap_content"
						android:layout_height="match_parent"
						android:padding="8dp"
						android:orientation="vertical"
						android:layout_weight="1" />
					<EditText
						android:id="@+id/spacingET"
						android:layout_width="70dp"
						android:layout_height="wrap_content"
						android:layout_marginLeft="6dp"
						android:layout_marginRight="6dp"
						android:padding="8dp"
						android:background="@android:color/transparent"
						android:gravity="center_horizontal|center_vertical"
						android:text="0.00"
						android:textSize="12sp"
						android:textColor="#FFFFFF"
						android:textColorHint="#757575"
						android:singleLine="true"
						android:inputType="numberDecimal"
						android:imeOptions="actionDone" />
				</LinearLayout>
				<TextView
					android:id="@+id/textview6"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="2dp"
					android:text="Angle"
					android:textSize="18sp"
					android:textColor="#FFFFFF" />
				<LinearLayout
					android:id="@+id/Ac_ner"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:orientation="horizontal">
					<com.inflps.pcd.WIDGET.SLIDERS.RotaryJogSlider
						android:id="@+id/angleSeek"
						android:layout_width="wrap_content"
						android:layout_height="match_parent"
						android:padding="8dp"
						android:orientation="vertical"
						android:layout_weight="1" />
					<EditText
						android:id="@+id/angleET"
						android:layout_width="70dp"
						android:layout_height="wrap_content"
						android:layout_marginLeft="6dp"
						android:layout_marginRight="6dp"
						android:padding="8dp"
						android:background="@android:color/transparent"
						android:gravity="center_horizontal|center_vertical"
						android:text="0.00"
						android:textSize="12sp"
						android:textColor="#FFFFFF"
						android:textColorHint="#757575"
						android:singleLine="true"
						android:inputType="numberDecimal"
						android:imeOptions="actionDone" />
				</LinearLayout>
				<TextView
					android:id="@+id/txtFP"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="2dp"
					android:text="Following the path"
					android:textSize="18sp"
					android:textColor="#FFFFFF" />
				<LinearLayout
					android:id="@+id/FPc_ner"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:orientation="horizontal">
					<CheckBox
						android:id="@+id/followingPathCB"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:gravity="center_vertical"
						android:text="True"
						android:textSize="14sp"
						android:textColor="#FFFFFF"
						android:checked="true" />
				</LinearLayout>
				<TextView
					android:id="@+id/txtSJ"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="2dp"
					android:text="Scatter jitter"
					android:textSize="18sp"
					android:textColor="#FFFFFF" />
				<LinearLayout
					android:id="@+id/SJc_ner"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:orientation="horizontal">
					<com.inflps.pcd.WIDGET.SLIDERS.RotaryJogSlider
						android:id="@+id/scatterSeek"
						android:layout_width="wrap_content"
						android:layout_height="match_parent"
						android:padding="8dp"
						android:orientation="vertical"
						android:layout_weight="1" />
					<EditText
						android:id="@+id/scatterJitterET"
						android:layout_width="70dp"
						android:layout_height="wrap_content"
						android:layout_marginLeft="6dp"
						android:layout_marginRight="6dp"
						android:padding="8dp"
						android:background="@android:color/transparent"
						android:gravity="center_horizontal|center_vertical"
						android:text="0.00"
						android:textSize="12sp"
						android:textColor="#FFFFFF"
						android:textColorHint="#757575"
						android:singleLine="true"
						android:inputType="numberDecimal"
						android:imeOptions="actionDone" />
				</LinearLayout>
				<TextView
					android:id="@+id/txtJA"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="2dp"
					android:text="Jitter angle"
					android:textSize="18sp"
					android:textColor="#FFFFFF" />
				<LinearLayout
					android:id="@+id/JAc_ner"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:orientation="horizontal">
					<com.inflps.pcd.WIDGET.SLIDERS.RotaryJogSlider
						android:id="@+id/jitterAngleSeek"
						android:layout_width="wrap_content"
						android:layout_height="match_parent"
						android:padding="8dp"
						android:orientation="vertical"
						android:layout_weight="1" />
					<EditText
						android:id="@+id/jitterAngleET"
						android:layout_width="70dp"
						android:layout_height="wrap_content"
						android:layout_marginLeft="6dp"
						android:layout_marginRight="6dp"
						android:padding="8dp"
						android:background="@android:color/transparent"
						android:gravity="center_horizontal|center_vertical"
						android:text="0.00"
						android:textSize="12sp"
						android:textColor="#FFFFFF"
						android:textColorHint="#757575"
						android:singleLine="true"
						android:inputType="numberDecimal"
						android:imeOptions="actionDone" />
				</LinearLayout>
				<TextView
					android:id="@+id/txtSzJ"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="2dp"
					android:text="Size jitter"
					android:textSize="18sp"
					android:textColor="#FFFFFF" />
				<LinearLayout
					android:id="@+id/SzJc_ner"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:orientation="horizontal">
					<com.inflps.pcd.WIDGET.SLIDERS.RotaryJogSlider
						android:id="@+id/sizeSeek"
						android:layout_width="wrap_content"
						android:layout_height="match_parent"
						android:padding="8dp"
						android:orientation="vertical"
						android:layout_weight="1" />
					<EditText
						android:id="@+id/sizeET"
						android:layout_width="70dp"
						android:layout_height="wrap_content"
						android:layout_marginLeft="6dp"
						android:layout_marginRight="6dp"
						android:padding="8dp"
						android:background="@android:color/transparent"
						android:gravity="center_horizontal|center_vertical"
						android:text="0.00"
						android:textSize="12sp"
						android:textColor="#FFFFFF"
						android:textColorHint="#757575"
						android:singleLine="true"
						android:inputType="numberDecimal"
						android:imeOptions="actionDone" />
				</LinearLayout>
			</LinearLayout>
		</ScrollView>
	</LinearLayout>
</LinearLayout>